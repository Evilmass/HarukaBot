HOST=127.0.0.1
PORT=7070
SECRET=
ACCESS_TOKEN=
SUPERUSERS=[]
COMMAND_START=[""]

# HarukaBot Configs
HARUKA_DIR="./data/"
HARUKA_TO_ME=False
HARUKA_LIVE_OFF_NOTIFY=True
HARUKA_DYNAMIC_ENABLED=True
HARUKA_DYNAMIC_INTERVAL=60
HARUKA_LIVE_INTERVAL=10

# 每日直播时长统计的切日小时（Asia/Shanghai，0 表示自然日）
HARUKA_LIVE_DURATION_DAY_START_HOUR=0
HARUKA_LIVE_DURATION_TOP_N=8
HARUKA_BROWSER_UA="Mozilla/5.0 (Linux; Android 10; Redmi K30 Pro) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/90.0.4430.210 Mobile Safari/537.36"

# 捕捉并转发 B 站视频的群号；留空数组表示关闭
HARUKA_BILI_VIDEO_GROUPS=[]
# 可选：登录 Cookie 可获取账号有权观看的清晰度，请勿提交到版本库
HARUKA_BILI_VIDEO_COOKIE=
HARUKA_BILI_VIDEO_QUALITY=50
HARUKA_BILI_VIDEO_MAX_SIZE_MB=512
HARUKA_BILI_VIDEO_MAX_LINKS=3
HARUKA_BILI_VIDEO_CONCURRENCY=2
HARUKA_BILI_VIDEO_FFMPEG=ffmpeg
# 下载、FFmpeg 处理及 OneBot 视频发送的超时时间（秒）
HARUKA_BILI_VIDEO_TIMEOUT=600

# Web 管理页面（访问 http://<服务器地址>:7070/admin/）
# 未配置密码时，页面的管理 API 会保持禁用
HARUKA_WEB_PASSWORD=
# 可选；留空时使用管理密码派生会话签名密钥
HARUKA_WEB_SECRET=
HARUKA_WEB_SESSION_TTL=43200
# 仅在通过 HTTPS 访问时设为 True
HARUKA_WEB_COOKIE_SECURE=False

# Browser
PLAYWRIGHT_SKIP_BROWSER_GC=1

# Ignore_group
IGNORE_GROUP=[1, 2]

# # REDIS
# REDIS_HOST=0.0.0.0
# REDIS_PORT=6379
